# LOAB — LLM Provider API Keys
# Copy this file to .env and fill in your keys.
# Never commit .env to version control.

# ── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── OpenAI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Google Gemini ───────────────────────────────────────────────────────────
GOOGLE_API_KEY=

# ── Mistral ─────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=

# ── Cohere ──────────────────────────────────────────────────────────────────
COHERE_API_KEY=

# ── AWS Bedrock ─────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-2

# ── Azure OpenAI (LiteLLM) ──────────────────────────────────────────────────
# Note: LiteLLM expects the deployment name in the model string: azure/<deployment>
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=2024-02-01

# ── Azure AI / Anthropic on Foundry (LiteLLM) ──────────────────────────────
# Use model strings like azure_ai/claude-opus-4-6-2
AZURE_ANTHROPIC_API_BASE=

# ── MiniMax ─────────────────────────────────────────────────────────────────
# OpenAI-compatible API. Use model strings like openai/MiniMax-M2.5
# Docs: https://platform.minimaxi.com/
MINIMAX_API_KEY=
MINIMAX_API_BASE=https://api.minimax.io/v1

# ── xAI (Grok) ──────────────────────────────────────────────────────────────
XAI_API_KEY=

# ── Default model assignments ───────────────────────────────────────────────
# Set which model plays each agent role. Override in run_config.json per run.
# Format: <provider>/<model-id>  e.g. anthropic/claude-opus-4-6
DEFAULT_PROCESSING_OFFICER_MODEL=
DEFAULT_UNDERWRITER_MODEL=
DEFAULT_CREDIT_MANAGER_MODEL=
DEFAULT_COLLECTIONS_OFFICER_MODEL=
DEFAULT_HARDSHIP_ASSESSOR_MODEL=
DEFAULT_FRAUD_ANALYST_MODEL=
DEFAULT_COMPLIANCE_OFFICER_MODEL=
DEFAULT_CUSTOMER_SIMULATION_MODEL=
